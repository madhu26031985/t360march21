# Copy to `.env` in the repo root, then fill in values from Supabase → Project Settings → API.
# Required for local web (and mobile) dev:

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: if EXPO_PUBLIC_SUPABASE_URL is an HTTP-only proxy, set the real Supabase host for web
# so Realtime WebSockets work in the browser:
# EXPO_PUBLIC_SUPABASE_WEB_URL=https://YOUR_PROJECT_REF.supabase.co

# Google sign-in (Supabase Dashboard → Authentication → Providers → Google):
# - Add web redirect URLs, e.g. http://localhost:8081/login and your production /login URL.
# - Add the deep link Expo prints for Linking.createURL('/login'), e.g. toastmaster360://login
#   (and exp://... for dev client), under Redirect URLs.
