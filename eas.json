{
  "cli": {
    "version": "18.8.1",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_NO_CAPABILITY_SYNC": "1"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_AGENDA_WEB_HOST": "https://app.t360.in",
        "EXPO_NO_CAPABILITY_SYNC": "1"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "simulator": false,
        "buildConfiguration": "Release",
        "image": "latest"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_AGENDA_WEB_HOST": "https://app.t360.in",
        "EXPO_NO_CAPABILITY_SYNC": "1"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "buildConfiguration": "Release",
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {}
  }
}