{
  "name": "t360",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "CI=0 EXPO_NO_TELEMETRY=1 expo start --web --clear",
    "web": "CI=0 EXPO_NO_TELEMETRY=1 expo start --web --clear",
    "build:web": "expo export --platform web && npm run post-build:web",
    "post-build:web": "node scripts/post-build-web.js",
    "lint": "expo lint",
    "pre-build": "node scripts/pre-build-check.js",
    "build:apk": "npm run pre-build && EAS_NO_VCS=1 npx eas-cli@18.8.1 build --platform android --profile preview --non-interactive",
    "build:aab": "npm run pre-build && EAS_NO_VCS=1 npx eas-cli@18.8.1 build --platform android --profile production --non-interactive",
    "build:safe": "npm run build:apk",
    "build:monitor": "node scripts/build-monitor.js android preview",
    "submit:android": "EAS_NO_VCS=1 npx eas-cli@18.8.1 submit --platform android --latest",
    "emergency-recovery": "node scripts/emergency-recovery.js",
    "clean": "rm -rf node_modules package-lock.json .expo && npm install",
    "doctor": "expo doctor",
    "fix-deps": "npx expo install --check && npm audit fix",
    "test:supabase": "node scripts/test-supabase-connection.js",
    "test:web": "node scripts/start-product-web.js",
    "local:test-web": "node scripts/local-web-server.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@supabase/supabase-js": "^2.55.0",
    "@tanstack/react-query": "^5.95.2",
    "expo": "^55.0.17",
    "expo-build-properties": "~55.0.13",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.28",
    "expo-device": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-image": "~55.0.9",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "^55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "html2canvas": "^1.4.1",
    "i18n-iso-countries": "^7.14.0",
    "jspdf": "^4.1.0",
    "lucide-react-native": "^0.475.0",
    "moment-timezone": "^0.6.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "^6.0.0",
    "react-native": "0.83.6",
    "react-native-app-intro-slider": "^4.0.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/cli": "^0.10.17",
    "@expo/config-plugins": "^55.0.8",
    "@types/react": "~18.2.14",
    "@types/react-native-app-intro-slider": "^3.0.1",
    "babel-preset-expo": "~55.0.18",
    "eas-cli": "^18.8.1",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~9.2.0",
    "knip": "^5.63.0",
    "typescript": "~5.8.3"
  }
}
