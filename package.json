{
  "name": "t360",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "CI=0 EXPO_NO_TELEMETRY=1 expo start --web --clear",
    "web": "CI=0 EXPO_NO_TELEMETRY=1 expo start --web --clear",
    "build:web": "expo export --platform web && npm run post-build:web",
    "post-build:web": "node scripts/post-build-web.js",
    "lint": "expo lint",
    "pre-build": "node scripts/pre-build-check.js",
    "build:apk": "npm run pre-build && EAS_NO_VCS=1 npx eas-cli build --platform android --profile preview --non-interactive",
    "build:aab": "npm run pre-build && EAS_NO_VCS=1 npx eas-cli build --platform android --profile production --non-interactive",
    "build:safe": "npm run build:apk",
    "build:monitor": "node scripts/build-monitor.js android preview",
    "submit:android": "EAS_NO_VCS=1 npx eas-cli submit --platform android --latest",
    "emergency-recovery": "node scripts/emergency-recovery.js",
    "clean": "rm -rf node_modules package-lock.json .expo && npm install",
    "doctor": "expo doctor",
    "fix-deps": "npx expo install --check && npm audit fix",
    "test:supabase": "node scripts/test-supabase-connection.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/datetimepicker": "8.4.1",
    "@supabase/supabase-js": "^2.55.0",
    "expo": "~53.0.25",
    "expo-build-properties": "~0.14.8",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.3",
    "expo-crypto": "^14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-document-picker": "^13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-image-picker": "^16.1.4",
    "expo-linking": "~7.1.3",
    "expo-router": "~5.1.10",
    "expo-sharing": "^13.1.5",
    "expo-splash-screen": "~0.30.6",
    "expo-status-bar": "~2.2.2",
    "expo-system-ui": "~5.0.11",
    "expo-web-browser": "^14.2.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.1.0",
    "lucide-react-native": "^0.475.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-error-boundary": "^6.0.0",
    "react-native": "0.79.6",
    "react-native-app-intro-slider": "^4.0.4",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/cli": "^0.24.20",
    "@types/react": "~19.0.10",
    "@types/react-native-app-intro-slider": "^3.0.1",
    "babel-preset-expo": "~13.0.0",
    "eas-cli": "^16.18.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~9.2.0",
    "knip": "^5.63.0",
    "typescript": "~5.8.3"
  }
}
