{
  "expo": {
    "name": "T360",
    "slug": "toastmaster360-mobile",
    "version": "84",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "toastmaster360",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.toastmaster360.mobile",
      "deploymentTarget": "18.1",
      "buildNumber": "84",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library so you can select a profile picture.",
        "NSCameraUsageDescription": "This app needs access to your camera so you can take a profile picture.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.toastmaster360.mobile",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "versionCode": 84,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "t360.in",
              "pathPrefix": "/weblogin"
            },
            {
              "scheme": "https",
              "host": "www.t360.in",
              "pathPrefix": "/weblogin"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/icon.png",
      "name": "T360",
      "build": {
        "babel": {
          "include": ["@supabase/supabase-js"]
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to your photo library so you can select a profile picture.",
          "cameraPermission": "This app needs access to your camera so you can take a profile picture."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "18.1"
          },
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": "",
      "router": {},
      "eas": {
        "projectId": "0429620c-e876-4b8f-9d0a-3eb2ba451242"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/weblogin"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}