# /{club-segment}/agenda/{meetingNo}/{meetingId} → Expo baseUrl (slug or legacy club UUID)
/:clubId/agenda/:meetingNo/:meetingId  /.netlify/functions/agenda-preview/agenda/:clubId/:meetingNo/:meetingId?mode=agenda  200

# Short public agenda: /a/{meetingId}
/a/:meetingId  /.netlify/functions/agenda-preview/short/:meetingId  200

# /weblogin/* agenda URLs are served by the SPA (see /weblogin/* below), not agenda-preview.

# Branded short agenda: /{club-slug}/a/{meetingId}
/:brand/a/:meetingId  /.netlify/functions/agenda-preview/brand/:brand/:meetingId  200

# Netlify redirects for SPA routing at /weblogin
/weblogin    /weblogin/index.html    200
/weblogin/*  /weblogin/index.html  200
