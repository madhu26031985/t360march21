# Serve OG image path through binary image function (must be before SPA rewrites)
/og/meeting-:meetingNo.jpg  /.netlify/functions/og-meeting-image?no=:meetingNo  200!

# /{club-segment}/agenda/{meetingNo}/{meetingId} → SSR OG shell then SPA (slug or legacy club UUID)
/:clubId/agenda/:meetingNo/:meetingId  /.netlify/functions/agenda-preview/agenda/:clubId/:meetingNo/:meetingId?mode=agenda  200

# Short public agenda: /a/{meetingId}
/a/:meetingId  /.netlify/functions/agenda-preview/short/:meetingId  200

# Same agenda routes under /weblogin (shared links) — SSR for social crawlers + meta refresh for humans
/weblogin/:club/agenda/:meetingNo/:meetingId  /.netlify/functions/agenda-preview/agenda/:club/:meetingNo/:meetingId?mode=agenda  200
/weblogin/:brand/a/:meetingId  /.netlify/functions/agenda-preview/brand/:brand/:meetingId  200
/weblogin/a/:meetingId  /.netlify/functions/agenda-preview/short/:meetingId  200

# Branded short agenda: /{club-slug}/a/{meetingId}
/:brand/a/:meetingId  /.netlify/functions/agenda-preview/brand/:brand/:meetingId  200

# Netlify redirects for SPA routing at /weblogin
/weblogin    /weblogin/index.html    200
/weblogin/*  /weblogin/index.html  200
